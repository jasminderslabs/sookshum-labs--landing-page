<section
  class='max-w-480 mx-auto px-5 md:px-10 xl:px-20! pt-15 pb-10 md:pt-17.5 md:pb-10 lg:pb-20 lg:pt-30 overflow-hidden contact-card'
>
  <div
    class='w-full flex flex-col md:justify-normal md:flex-row items-center rounded-[20px] lg:rounded-4xl bg-[#282828B2] gap-5 dark-btn-shadow dropdown-bg dropdown-shadow-button relative h-167.75 md:h-fit wrapper'
  >
    <div
      class='text-white w-full px-5 py-7 md:ml-7 lg:ml-17.25 md:py-8 md:px-0 lg:pb-18 lg:pt-[72px] md:max-w-[320px] xl:max-w-98.75!'
    >
      <div class='flex flex-col justify-between gap-4 lg:gap-7.5! w-full'>
        <h2
          class='text-4xl md:text-5xl text-[28px] md:text-[36px] lg:text-[52px] xl:text-7xl! font-semibold text-left hero-heading
          leading-8.25 md:leading-10 lg:leading-14.25 pb-[6px] xl:leading-19.75! tracking-tight w-full'
        >
          Let's Work <br /> Together
        </h2>
        <p
          class='text-[14px] lg:text-[16px] xl:text-lg! text-[#f8f8f8b2] shrink xl:leading-8! contact-content'
        >
          Contact us today to collaborate and bring your vision to life with
          expert guidance and innovative solutions.
        </p>
      </div>
      <div
        class='py-0 px-5 xl:px-6! h-12 xl:h-13.75! flex items-center rounded-full bg-[#E68624] cursor-pointer transition-all dark-bg duration-700 hover:[backdrop-filter:blur(100px)] dark-btn-shadow w-fit lg:mt-15 xl:mt-16.5! 2xl:mt-15! mt-7.5 md:mt-12.5'
      >
        <button
          class='w-full h-full font-medium text-[13px] xl:text-[16px]! flex justify-between items-center gap-2 text-white'
        >
          Request a quote <img
            alt='top-arrow'
            loading='lazy'
            width='200'
            height='200'
            decoding='async'
            data-nimg='1'
            class='w-2 h-2 sm:w-2.5 sm:h-2.5'
            src='/arrow.svg'
            style='color: transparent;'
          />
        </button>
      </div>
    </div>

    <div class='absolute -right-12 h-full w-auto image-container'>
      <div class='relative flex w-full h-full items-center main'>
        <span
          class='first-ball z-999 block absolute top-0! left-[23%]! bg-red-200 w-10.5 h-10.5 lg:w-13 lg:h-13 xl:h-18! xl:w-18! rounded-full'
          style='background: linear-gradient(rgb(255, 156, 0) 0%, rgb(245, 99, 0) 100%)'
        ></span>
        <span
          class='second-ball w-4.5 h-4.5 lg:w-6 lg:h-6 xl:w-8.5! xl:h-8.5! rounded-full shadow-xl absolute z-999 xl:bottom-[5.5%]! left-[16.3%]!'
          style='background: linear-gradient(206.92deg, rgb(255, 255, 255) 59.29%, rgb(153, 153, 153) 85.78%);'
        ></span>
        <span
          class='third-ball z-999 h-8 w-8 lg:w-10.5 lg:h-10.5 xl:w-13! xl:h-13! rounded-full shadow-xl absolute right-[20%]! xl:-bottom-[3%]!'
          style='background: linear-gradient(206.92deg, rgb(255, 255, 255) 59.29%, rgb(153, 153, 153) 85.78%);'
        ></span>

        <img
          src='/work-together.webp'
          alt='work-together-image'
          width='3600'
          height='3600'
          class='lg:mt-10 xl:mt-0! sm:m-0 translate-y-[-12%] image mx-auto shrink max-h-67.5 sm:max-h-100 md:max-h-127.5 w-fit sm:h-auto sm:max-w-96.25 md:max-w-100 lg:max-w-147.5 lg:max-h-[480px] xl:max-w-[750px]! 2xl:max-h-[510px]!'
        />
      </div>
    </div>
  </div>
</section>

<style>
  @media screen and (width: 1024px) {
    .contact-card {
      padding-bottom: 40px;
    }
  }
  @media screen and (width: 1024px) {
    section {
      padding-top: 90px;
    }
    .contact-content {
      font-size: 14px;
      line-height: 20px;
    }
    .third-ball {
      bottom: -3% !important;
    }
    .second-ball {
      bottom: 5.5% !important;
    }
  }
  @media screen and (width: 1280px) {
    /* section {
      padding-top: 90px;
    } */
    .contact-content {
      font-size: 14px;
      line-height: 20px;
    }
    .third-ball {
      bottom: -3% !important;
    }
    .second-ball {
      bottom: 5.5% !important;
    }
  }
  .image,
  .first-ball,
  .second-ball,
  .third-ball {
    will-change: transform;
  }
  @media screen and (max-width: 650px) {
    .image-container {
      position: relative;
      right: 0px;
    }
  }
  @media screen and (max-width: 960px) {
    .third-ball {
      bottom: 10%;
    }
    .second-ball {
      bottom: 20%;
    }
    .main {
      height: 360px;
      width: 100%;
    }
    .wrapper {
      gap: 32px;
    }
    .image {
      margin-top: -32px !important;
      /* height: 70px !important; */
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  if (typeof window !== "undefined") {
    gsap.registerPlugin(ScrollTrigger);

    // Function to wait for images
    const waitForImages = () => {
      const images = Array.from(
        document.querySelectorAll(".image"),
      ) as HTMLImageElement[];
      return Promise.all(
        images.map((img) => {
          if (img.complete) return Promise.resolve();
          return new Promise((resolve) => {
            img.onload = resolve;
            img.onerror = resolve; // Continue even if an image fails
          });
        }),
      );
    };

    const initializeGSAP = () => {
      const section = document.querySelector(".contact-card");
      if (!section) return;

      // Clean up previous triggers to prevent memory leaks/glitches
      // ScrollTrigger.getAll().forEach((t) => t.kill());

      let ctx = gsap.context(() => {
        // IMAGE PARALLAX
        const image = section.querySelector(".image");
        if (image) {
          gsap.to(image, {
            yPercent: 20,
            ease: "none",
            scrollTrigger: {
              trigger: image,
              start: "top bottom",
              end: "bottom top",
              scrub: true,
            },
          });
        }

        // TOP BALL
        const firstBall = section.querySelector(".first-ball");
        if (firstBall) {
          gsap.to(firstBall, {
            yPercent: -50,
            ease: "none",
            scrollTrigger: {
              trigger: firstBall,
              start: "top bottom",
              end: "bottom top",
              scrub: true,
            },
          });
        }

        // BOTTOM BALLS
        const bottomBalls = [
          section.querySelector(".second-ball"),
          section.querySelector(".third-ball"),
        ];
        bottomBalls.forEach((ball) => {
          if (ball) {
            gsap.to(ball, {
              yPercent: -80,
              ease: "none",
              scrollTrigger: {
                trigger: ball,
                start: "top bottom",
                end: "bottom top",
                scrub: true,
              },
            });
          }
        });
      }, section);

      ScrollTrigger.refresh();
      return ctx;
    };

    let animationCtx;

    // Initialize after load
    window.addEventListener("load", async () => {
      await waitForImages();
      animationCtx = initializeGSAP();
    });

    // Handle resize
    window.addEventListener("resize", () => {
      ScrollTrigger.refresh();
    });
  }
</script>
